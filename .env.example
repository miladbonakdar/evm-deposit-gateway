# HTTP
PORT=3000
NODE_ENV=development

# Local Postgres for dev. Docker Compose can override this for container runs.
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgres://postgres:postgres@localhost:5433/crypto_payment

# Business network/token settings live in JSON, not env.
# Copy config/networks.example.json to config/networks.local.json and edit it.
NETWORK_CONFIG_PATH=config/networks.local.json

# Admin API. Use a long random value in production.
ADMIN_API_KEY=change-me-admin-key-for-local-dev

# Dashboard login and signed session token.
ADMIN_DASHBOARD_USERNAME=admin
ADMIN_DASHBOARD_PASSWORD=change-me-dashboard-password
ADMIN_SESSION_SECRET=change-me-dashboard-session-secret-at-least-32-chars
ADMIN_SESSION_TTL_SECONDS=28800

# 32-byte base64 key. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY_BASE64=replace-with-32-byte-base64-key

# Client HMAC request window.
REQUEST_MAX_SKEW_SECONDS=300

# Webhook delivery.
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_BASE_RETRY_SECONDS=5
WEBHOOK_MAX_RETRY_DELAY_SECONDS=86400

# Direct treasury matching. 500 basis points = 5%.
DIRECT_TREASURY_MATCH_TOLERANCE_BPS=500

# Worker.
WORKER_POLL_INTERVAL_MS=15000

# Mainnet RPC endpoints and gas-wallet secrets.
# Enable a network by setting RPC_URL_<NETWORK> here and at least one token
# contract in NETWORK_CONFIG_PATH.

# Ethereum
RPC_URL_ETHEREUM=
GAS_WALLET_PRIVATE_KEY_ETHEREUM=

# BSC
RPC_URL_BSC=
GAS_WALLET_PRIVATE_KEY_BSC=

# Polygon
RPC_URL_POLYGON=
GAS_WALLET_PRIVATE_KEY_POLYGON=

# Arbitrum
RPC_URL_ARBITRUM=
GAS_WALLET_PRIVATE_KEY_ARBITRUM=

# Optimism
RPC_URL_OPTIMISM=
GAS_WALLET_PRIVATE_KEY_OPTIMISM=

# Base
RPC_URL_BASE=
GAS_WALLET_PRIVATE_KEY_BASE=

# TRON mainnet.
# TRON private keys may be set with or without 0x prefix.
RPC_URL_TRON=
EVENT_SERVER_URL_TRON=
GAS_WALLET_PRIVATE_KEY_TRON=
