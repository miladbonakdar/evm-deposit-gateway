# HTTP
PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crypto_payment

# Admin API. Use a long random value in production.
ADMIN_API_KEY=change-me-admin-key

# 32-byte base64 key. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY_BASE64=replace-with-32-byte-base64-key

# Merchant HMAC request window.
REQUEST_MAX_SKEW_SECONDS=300

# Webhook delivery.
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_BASE_RETRY_SECONDS=30

# Worker.
WORKER_POLL_INTERVAL_MS=15000

# Enable each EVM network by setting its RPC URL and at least one token contract + decimals.
# Chain IDs are fixed internally for the named mainnets; env values below are documentation.

# Ethereum
RPC_URL_ETHEREUM=
CHAIN_ID_ETHEREUM=1
CONFIRMATIONS_ETHEREUM=12
SCAN_FROM_BLOCK_ETHEREUM=0
MAX_SCAN_BLOCKS_ETHEREUM=1000
GAS_WALLET_PRIVATE_KEY_ETHEREUM=
MIN_GAS_WEI_ETHEREUM=2000000000000000
GAS_TOPUP_WEI_ETHEREUM=5000000000000000
USDT_CONTRACT_ETHEREUM=
USDT_DECIMALS_ETHEREUM=6
USDC_CONTRACT_ETHEREUM=
USDC_DECIMALS_ETHEREUM=6

# BSC
RPC_URL_BSC=
CHAIN_ID_BSC=56
CONFIRMATIONS_BSC=20
SCAN_FROM_BLOCK_BSC=0
MAX_SCAN_BLOCKS_BSC=2000
GAS_WALLET_PRIVATE_KEY_BSC=
MIN_GAS_WEI_BSC=2000000000000000
GAS_TOPUP_WEI_BSC=5000000000000000
USDT_CONTRACT_BSC=
USDT_DECIMALS_BSC=18
USDC_CONTRACT_BSC=
USDC_DECIMALS_BSC=18

# Polygon
RPC_URL_POLYGON=
CHAIN_ID_POLYGON=137
CONFIRMATIONS_POLYGON=128
SCAN_FROM_BLOCK_POLYGON=0
MAX_SCAN_BLOCKS_POLYGON=5000
GAS_WALLET_PRIVATE_KEY_POLYGON=
MIN_GAS_WEI_POLYGON=20000000000000000
GAS_TOPUP_WEI_POLYGON=50000000000000000
USDT_CONTRACT_POLYGON=
USDT_DECIMALS_POLYGON=6
USDC_CONTRACT_POLYGON=
USDC_DECIMALS_POLYGON=6

# Arbitrum
RPC_URL_ARBITRUM=
CHAIN_ID_ARBITRUM=42161
CONFIRMATIONS_ARBITRUM=64
SCAN_FROM_BLOCK_ARBITRUM=0
MAX_SCAN_BLOCKS_ARBITRUM=5000
GAS_WALLET_PRIVATE_KEY_ARBITRUM=
MIN_GAS_WEI_ARBITRUM=2000000000000000
GAS_TOPUP_WEI_ARBITRUM=5000000000000000
USDT_CONTRACT_ARBITRUM=
USDT_DECIMALS_ARBITRUM=6
USDC_CONTRACT_ARBITRUM=
USDC_DECIMALS_ARBITRUM=6

# Optimism
RPC_URL_OPTIMISM=
CHAIN_ID_OPTIMISM=10
CONFIRMATIONS_OPTIMISM=64
SCAN_FROM_BLOCK_OPTIMISM=0
MAX_SCAN_BLOCKS_OPTIMISM=5000
GAS_WALLET_PRIVATE_KEY_OPTIMISM=
MIN_GAS_WEI_OPTIMISM=2000000000000000
GAS_TOPUP_WEI_OPTIMISM=5000000000000000
USDT_CONTRACT_OPTIMISM=
USDT_DECIMALS_OPTIMISM=6
USDC_CONTRACT_OPTIMISM=
USDC_DECIMALS_OPTIMISM=6

# Base
RPC_URL_BASE=
CHAIN_ID_BASE=8453
CONFIRMATIONS_BASE=64
SCAN_FROM_BLOCK_BASE=0
MAX_SCAN_BLOCKS_BASE=5000
GAS_WALLET_PRIVATE_KEY_BASE=
MIN_GAS_WEI_BASE=2000000000000000
GAS_TOPUP_WEI_BASE=5000000000000000
USDT_CONTRACT_BASE=
USDT_DECIMALS_BASE=6
USDC_CONTRACT_BASE=
USDC_DECIMALS_BASE=6
