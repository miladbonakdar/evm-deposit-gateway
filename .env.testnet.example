# Copy this file to .env.testnet before running:
# docker compose -f docker-compose.yml -f docker-compose.testnet.yml up --build

PORT=3000
NODE_ENV=development

# Postgres. Docker Compose publishes the local database on 5432 by default.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crypto_payment

# Testnet network/token settings live in JSON, not env.
# Copy config/networks.testnet.example.json to config/networks.testnet.local.json and edit it.
NETWORK_CONFIG_PATH=config/networks.testnet.local.json

ADMIN_API_KEY=change-me-admin-key-for-testnet
OWNER_MERCHANT_ID=00000000-0000-4000-8000-000000000001
OWNER_MERCHANT_NAME=Owner
ADMIN_DASHBOARD_USERNAME=admin
ADMIN_DASHBOARD_PASSWORD=change-me-dashboard-password
ADMIN_SESSION_SECRET=change-me-dashboard-session-secret-at-least-32-chars
ADMIN_SESSION_TTL_SECONDS=28800

# 32-byte base64 key. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY_BASE64=replace-with-32-byte-base64-key

REQUEST_MAX_SKEW_SECONDS=300
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_BASE_RETRY_SECONDS=5
WEBHOOK_MAX_RETRY_DELAY_SECONDS=86400
WORKER_POLL_INTERVAL_MS=15000

# Testnet RPC endpoints and gas-wallet secrets.
# Enable a network by setting RPC_URL_<TESTNET> here and at least one token
# contract in NETWORK_CONFIG_PATH.

# Sepolia
RPC_URL_SEPOLIA=
GAS_WALLET_PRIVATE_KEY_SEPOLIA=

# BSC Testnet
RPC_URL_BSC_TESTNET=
GAS_WALLET_PRIVATE_KEY_BSC_TESTNET=

# Polygon Amoy
RPC_URL_POLYGON_AMOY=
GAS_WALLET_PRIVATE_KEY_POLYGON_AMOY=

# Arbitrum Sepolia
RPC_URL_ARBITRUM_SEPOLIA=
GAS_WALLET_PRIVATE_KEY_ARBITRUM_SEPOLIA=

# Optimism Sepolia
RPC_URL_OPTIMISM_SEPOLIA=
GAS_WALLET_PRIVATE_KEY_OPTIMISM_SEPOLIA=

# Base Sepolia
RPC_URL_BASE_SEPOLIA=
GAS_WALLET_PRIVATE_KEY_BASE_SEPOLIA=

# TRON Nile.
# TRON private keys may be set with or without 0x prefix.
RPC_URL_NILE=
EVENT_SERVER_URL_NILE=
GAS_WALLET_PRIVATE_KEY_NILE=
