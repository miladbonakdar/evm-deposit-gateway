# Copy this file to .env.testnet before running:
# docker compose -f docker-compose.yml -f docker-compose.testnet.yml up --build

PORT=3000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crypto_payment
ADMIN_API_KEY=change-me-admin-key-for-testnet

# 32-byte base64 key. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY_BASE64=replace-with-32-byte-base64-key

REQUEST_MAX_SKEW_SECONDS=300
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_BASE_RETRY_SECONDS=30
WORKER_POLL_INTERVAL_MS=15000

# Testnet note:
# USDT/USDC testnet contracts are not consistently canonical across all networks.
# Use verified faucet contracts or deploy your own ERC-20 test tokens, then set
# their addresses below. Decimals should match the test token contract.

# Sepolia
RPC_URL_SEPOLIA=
CHAIN_ID_SEPOLIA=11155111
CONFIRMATIONS_SEPOLIA=3
SCAN_FROM_BLOCK_SEPOLIA=0
MAX_SCAN_BLOCKS_SEPOLIA=1000
GAS_WALLET_PRIVATE_KEY_SEPOLIA=
MIN_GAS_WEI_SEPOLIA=500000000000000
GAS_TOPUP_WEI_SEPOLIA=1000000000000000
USDT_CONTRACT_SEPOLIA=
USDT_DECIMALS_SEPOLIA=6
USDC_CONTRACT_SEPOLIA=
USDC_DECIMALS_SEPOLIA=6

