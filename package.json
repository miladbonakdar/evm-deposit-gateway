{
  "name": "evm-deposit-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.12",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "tronweb": "^6.3.0",
    "viem": "^2.21.45",
    "zod": "^3.24.1"
  },
  "overrides": {
    "axios": "^1.17.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
