{
  "name": "evm-deposit-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "node scripts/dev-both.mjs .env",
    "dev:dashboard": "vite --host 0.0.0.0",
    "dev:testnet": "node scripts/dev-both.mjs .env.testnet",
    "dev:worker": "tsx watch src/worker.ts",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "build": "npm run build:dashboard && tsc -p tsconfig.build.json",
    "build:api": "tsc -p tsconfig.build.json",
    "build:dashboard": "vite build",
    "typecheck": "tsc --noEmit && tsc -p dashboard/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.12",
    "lucide-react": "^1.17.0",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "tronweb": "^6.3.0",
    "viem": "^2.21.45",
    "zod": "^3.24.1"
  },
  "overrides": {
    "axios": "^1.17.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
